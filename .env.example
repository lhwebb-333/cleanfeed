# Server
PORT=3001
NODE_ENV=development

# Frontend dev server
VITE_API_URL=http://localhost:3001

# Cache TTL in seconds (5 min default)
CACHE_TTL=300

# Optional: Redis URL for production caching
# REDIS_URL=redis://localhost:6379

# Financial Vertical API Keys (all free tier)
# FRED: https://fred.stlouisfed.org/docs/api/api_key.html (instant, free)
FRED_API_KEY=
# BLS: https://www.bls.gov/developers/ (optional — works without, higher limits with)
BLS_API_KEY=
# Alpha Vantage: https://www.alphavantage.co/support/#api-key (free, 25 req/day)
ALPHA_VANTAGE_API_KEY=
